# ========================================================================
# Quiz Platform - Environment Configuration
# Database: MySQL
# ========================================================================

# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=quiz_platform
DB_USERNAME=root
DB_PASSWORD=root

# Application Profile
APP_DB_PROFILE=mysql

# Optional: Server Port
SERVER_PORT=8080

# Optional: Hibernate Configuration
HIBERNATE_DIALECT=org.hibernate.dialect.MySQLDialect
